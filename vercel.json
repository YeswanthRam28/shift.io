{
  "version": 2,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(api|socket.io)/(.*)",
      "destination": "/server.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ]
}
